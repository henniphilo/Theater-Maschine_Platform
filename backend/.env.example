APP_NAME="AI Debate API"
APP_ENV="dev"
APP_DEBUG=false
# Frontend-URL für CORS (Docker: http://localhost:3003, lokal npm: http://localhost:3000)
CORS_ORIGINS='["http://localhost:3003","http://localhost:3000"]'

DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/aidebatte"
REDIS_URL="redis://localhost:6379/0"

# Trage hier deine API-Keys ein (Datei nicht committen)
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# TTS: auto = Siri auf Mac, edge-tts in Docker (kostenlos)
TTS_PROVIDER="auto"

# macOS say (nur Backend nativ auf dem Mac)
# Dramaturgen (GPT / Claude)
TTS_VOICE_OPENAI="Samantha"
TTS_VOICE_ANTHROPIC="Flo"
# Aufführung (Stimme A / B / Erzähler — getrennt von Dramaturgen)
TTS_VOICE_AI_A="Anna"
TTS_VOICE_AI_B="Martin"
TTS_VOICE_NARRATOR="Alex"

# edge-tts (Docker + Fallback) — Stimmen: edge-tts --list-voices
TTS_EDGE_VOICE_OPENAI="de-DE-ConradNeural"
TTS_EDGE_VOICE_ANTHROPIC="de-DE-KatjaNeural"
TTS_EDGE_VOICE_AI_A="de-DE-KillianNeural"
TTS_EDGE_VOICE_AI_B="de-DE-SeraphinaMultilingualNeural"
TTS_EDGE_VOICE_NARRATOR="de-DE-AmalaNeural"

# Live-Regie / Director
DIRECTOR_ENABLED=true
DIRECTOR_DRAMATURGY_MODE=llm
DRAMATURGY_DISCUSSION_ROUNDS_DEFAULT=1
DRAMATURGY_DISCUSSION_ROUNDS_MAX=2
DRAMATURGY_DISCUSSION_MAX_TOKENS=400
DRAMATURGY_DECISION_MAX_TOKENS=1200
DRAMATURGY_RULES_EXCERPT_CHARS=3500
DRAMATURGY_STATEMENTS_PER_DRAMATURG=2
DRAMATURGY_STATEMENT_MAX_CHARS=450
DIRECTOR_EXECUTE_MODE=sequenced
DIRECTOR_AUTOPILOT_DEFAULT=true
DIRECTOR_LOG_PATH="logs/director.log"
DIRECTOR_DATA_DIR="data"
OSC_HOST="127.0.0.1"
OSC_PORT=7000
OSC_DRY_RUN=false
OSC_LOG_COMMANDS=true
OSC_LOG_PATH=logs/osc.log
DIRECTOR_LOG_PATH=logs/director.log

# Licht (TCP an Lichtpult / Desk — Unter Tieren)
LIGHT_OUTPUT=tcp
LIGHT_OSC_MIRROR=true
LIGHT_TCP_HOST="10.101.90.112"
LIGHT_TCP_PORT=3032
LIGHT_TCP_PROTOCOL="1.0"
LIGHT_TCP_HANDSHAKE=none
LIGHT_TCP_CONNECT_DELAY=0.15
LIGHT_TCP_READ_ACK=false
LIGHT_OSC_HOST="10.101.90.112"
LIGHT_OSC_PORT=3032
LIGHT_OSC_TCP_FORMAT=binary
LIGHT_OSC_TCP_FRAMING=length_prefix

# Sound (MIDI an QLab/Ableton/Mischpult — Mapping in data/sound_midi_map.json)
SOUND_OUTPUT=midi
SOUND_OSC_MIRROR=false
# Mac: z. B. "IAC Driver Bus 1" — leer = erster verfügbarer Port
SOUND_MIDI_PORT=
SOUND_MIDI_CHANNEL=1
SOUND_MIDI_MAP_PATH=data/sound_midi_map.json
SOUND_CUES_PATH=data/sound_cues.json

# Video (Pixera OSC — Clips/Projektoren in media/video/*.csv)
VISUAL_OUTPUT=pixera
VIDEO_CUES_PATH=data/video_cues.json
# PIXERA_OSC_HOST=
# PIXERA_OSC_PORT=
